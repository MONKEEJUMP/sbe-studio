# ─────────────────────────────────────────────────────────────
# Supabase — project "sbe-pulse"
# Create: https://supabase.com/dashboard  →  New Project  →  name it "sbe-pulse"
# Copy the real values into .env.local (gitignored). Leave this template blank.
# ─────────────────────────────────────────────────────────────

# Project URL — Supabase → Project Settings → API → Project URL
SUPABASE_URL=

# Public anon key — Supabase → Project Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=

# Postgres connection string for Drizzle —
# Supabase → Project Settings → Database → Connection string → URI.
# Prefer the Connection Pooler URI (port 6543) for Vercel serverless.
DATABASE_URL=
